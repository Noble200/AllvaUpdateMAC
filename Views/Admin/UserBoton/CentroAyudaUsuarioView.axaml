<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Allva.Desktop.ViewModels.Admin.UserBoton"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             x:Class="Allva.Desktop.Views.Admin.UserBoton.CentroAyudaUsuarioView"
             x:DataType="vm:CentroAyudaUsuarioViewModel"
             Background="White">

    <Design.DataContext>
        <vm:CentroAyudaUsuarioViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#0b5394"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#084171"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#595959"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.secondary:pointerover">
            <Setter Property="Background" Value="#E8E8E8"/>
        </Style>
        <Style Selector="Button.faq-item">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.faq-item:pointerover">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#0b5394"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,30" Spacing="30">

            <!-- Header -->
            <StackPanel Spacing="8">
                <TextBlock Text="Centro de Ayuda"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#0b5394"/>
                <TextBlock Text="Recursos y documentación para administradores del sistema"
                           FontSize="14"
                           Foreground="#808080"/>
            </StackPanel>

            <!-- Sección Manual de Administrador -->
            <Border Background="#EBF5FF"
                    CornerRadius="12"
                    Padding="24">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0"
                            Width="48" Height="48"
                            CornerRadius="24"
                            Background="#0b5394"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center">
                        <Path Data="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"
                              Fill="White"
                              Width="24" Height="24"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="Manual de Administrador"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#0b5394"/>
                        <TextBlock Text="Guía completa para la gestión del sistema administrativo"
                                   FontSize="13"
                                   Foreground="#666666"/>
                    </StackPanel>
                    <Button Grid.Column="2"
                            Content="Descargar Manual"
                            Classes="primary"
                            Command="{Binding DescargarManualCommand}"
                            IsEnabled="{Binding TieneManual}"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0"/>
                </Grid>
            </Border>

            <!-- Sección de Contacto Soporte Técnico -->
            <StackPanel Spacing="15">
                <TextBlock Text="Soporte Técnico"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#333333"/>

                <Border Background="#F8F9FA"
                        CornerRadius="12"
                        Padding="20">
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                        <!-- Email -->
                        <Border Grid.Row="0" Grid.Column="0"
                                Width="40" Height="40"
                                CornerRadius="20"
                                Background="#0b5394"
                                Margin="0,0,16,0"
                                VerticalAlignment="Center">
                            <Path Data="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                                  Fill="White"
                                  Width="20" Height="20"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2" VerticalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="Correo Electrónico"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#333333"/>
                            <TextBlock Text="soporte@allva.com"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#0b5394"/>
                        </StackPanel>

                        <!-- Teléfono -->
                        <Border Grid.Row="1" Grid.Column="0"
                                Width="40" Height="40"
                                CornerRadius="20"
                                Background="#22C55E"
                                Margin="0,0,16,0"
                                VerticalAlignment="Center">
                            <Path Data="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"
                                  Fill="White"
                                  Width="18" Height="18"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Teléfono de Soporte"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#333333"/>
                            <TextBlock Text="{Binding TelefonoSoporte}"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#22C55E"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Preguntas Frecuentes para Administradores -->
            <StackPanel Spacing="15">
                <TextBlock Text="Preguntas Frecuentes"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#333333"/>

                <Button Classes="faq-item">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="¿Cómo gestionar los permisos de usuarios?"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="#333333"/>
                            <TextBlock Text="Aprende a configurar roles y permisos del sistema"
                                       FontSize="12"
                                       Foreground="#808080"/>
                        </StackPanel>
                        <Path Grid.Column="1"
                              Data="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"
                              Fill="#808080"
                              Width="20" Height="20"
                              Stretch="Uniform"
                              VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <Button Classes="faq-item">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="¿Cómo configurar los márgenes de beneficio?"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="#333333"/>
                            <TextBlock Text="Guía para establecer comisiones y márgenes"
                                       FontSize="12"
                                       Foreground="#808080"/>
                        </StackPanel>
                        <Path Grid.Column="1"
                              Data="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"
                              Fill="#808080"
                              Width="20" Height="20"
                              Stretch="Uniform"
                              VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <Button Classes="faq-item">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="¿Cómo generar informes y analíticas?"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="#333333"/>
                            <TextBlock Text="Accede a reportes detallados de operaciones"
                                       FontSize="12"
                                       Foreground="#808080"/>
                        </StackPanel>
                        <Path Grid.Column="1"
                              Data="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"
                              Fill="#808080"
                              Width="20" Height="20"
                              Stretch="Uniform"
                              VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <Button Classes="faq-item">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="¿Cómo editar el contenido del Front Office?"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="#333333"/>
                            <TextBlock Text="Personaliza noticias, packs y contenido visible"
                                       FontSize="12"
                                       Foreground="#808080"/>
                        </StackPanel>
                        <Path Grid.Column="1"
                              Data="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"
                              Fill="#808080"
                              Width="20" Height="20"
                              Stretch="Uniform"
                              VerticalAlignment="Center"/>
                    </Grid>
                </Button>
            </StackPanel>

            <!-- Información de Versión -->
            <Border Background="#F8F9FA"
                    CornerRadius="10"
                    Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="Información del Sistema"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#333333"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Versión:"
                                   FontSize="13"
                                   Foreground="#666666"/>
                        <TextBlock Text="{Binding VersionSistema}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#0b5394"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Botón Cerrar -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Content="Cerrar"
                        Classes="secondary"
                        Command="{Binding CerrarCommand}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
