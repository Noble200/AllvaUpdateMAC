<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Allva.Desktop.ViewModels.Admin"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="Allva.Desktop.Views.Admin.ManageUsersView"
             x:DataType="vm:ManageUsersViewModel">

    <UserControl.Styles>
        <!-- Estilo para boton primario -->
        <Style Selector="Button.btn-primary">
            <Setter Property="Background" Value="#0b5394"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-primary:pointerover">
            <Setter Property="Background" Value="#ffd966"/>
            <Setter Property="Foreground" Value="#0b5394"/>
        </Style>

        <!-- Estilo para boton secundario -->
        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="#6c757d"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.btn-action">
            <Setter Property="Background" Value="#0b5394"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-action:pointerover">
            <Setter Property="Background" Value="#ffd966"/>
            <Setter Property="Foreground" Value="#0b5394"/>
        </Style>

        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="#dc3545"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-danger:pointerover">
            <Setter Property="Background" Value="#c82333"/>
        </Style>

        <!-- Estilo para boton exportar (amarillo pastel) -->
        <Style Selector="Button.btn-export">
            <Setter Property="Background" Value="#fff3c4"/>
            <Setter Property="Foreground" Value="#5c4a00"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#ffd966"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-export:pointerover">
            <Setter Property="Background" Value="#ffe799"/>
        </Style>

        <Style Selector="Border.usuario-card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#e0e0e0"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="BoxShadow" Value="0 2 6 0 #12000000"/>
        </Style>
        <Style Selector="Border.usuario-card:pointerover">
            <Setter Property="BoxShadow" Value="0 3 10 0 #20000000"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#ccc"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="MinHeight" Value="42"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#0b5394"/>
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#ccc"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="MinHeight" Value="42"/>
        </Style>

        <Style Selector="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header eliminado - contenido movido a la sección de filtros -->

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Row="1">
            <!-- ÁREA DE FILTROS Y LISTA -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="28,20" Spacing="20">

                    <!-- FILTROS -->
                    <Border Background="White" CornerRadius="10" Padding="24"
                            BoxShadow="0 2 6 0 #10000000">
                        <StackPanel Spacing="16">
                            <TextBlock Text="FILTROS DE BUSQUEDA"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#0b5394"
                                       LetterSpacing="0.5"/>

                            <Grid ColumnDefinitions="*,*,*,*,*,*">

                                <!-- Buscar -->
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Buscar"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="#666" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding FiltroBusqueda}"
                                             Watermark="Nombre o usuario..."
                                             FontSize="14"/>
                                </StackPanel>

                                <!-- Comercio con autocompletado -->
                                <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                    <TextBlock Text="Comercio"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="#666" Margin="0,0,0,6"/>
                                    <Panel>
                                        <TextBox Text="{Binding FiltroComercio}"
                                                 Watermark="Nombre del comercio..."
                                                 FontSize="14"/>
                                        <!-- Lista de sugerencias -->
                                        <Border IsVisible="{Binding MostrarSugerenciasComercio}"
                                                Background="White"
                                                BorderBrush="#0b5394"
                                                BorderThickness="1"
                                                CornerRadius="0,0,6,6"
                                                Margin="0,42,0,0"
                                                ZIndex="100">
                                            <ItemsControl ItemsSource="{Binding SugerenciasComercio}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Background="Transparent"
                                                                BorderThickness="0"
                                                                HorizontalAlignment="Stretch"
                                                                HorizontalContentAlignment="Left"
                                                                Padding="12,8"
                                                                Cursor="Hand"
                                                                Command="{Binding $parent[UserControl].((vm:ManageUsersViewModel)DataContext).SeleccionarComercioSugeridoCommand}"
                                                                CommandParameter="{Binding}">
                                                            <Button.Styles>
                                                                <Style Selector="Button:pointerover">
                                                                    <Setter Property="Background" Value="#e3f2fd"/>
                                                                </Style>
                                                            </Button.Styles>
                                                            <TextBlock Text="{Binding}" FontSize="13" Foreground="#333"/>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </Panel>
                                </StackPanel>

                                <!-- Local -->
                                <StackPanel Grid.Column="2" Margin="8,0,8,0">
                                    <TextBlock Text="Local"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="#666" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding FiltroLocal}"
                                             Watermark="Código de local..."
                                             FontSize="14"/>
                                </StackPanel>

                                <!-- Estado -->
                                <StackPanel Grid.Column="3" Margin="8,0,8,0">
                                    <TextBlock Text="Estado"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="#666" Margin="0,0,0,6"/>
                                    <ComboBox SelectedItem="{Binding FiltroEstado}"
                                              HorizontalAlignment="Stretch"
                                              FontSize="14">
                                        <ComboBoxItem Content="Todos" FontSize="14"/>
                                        <ComboBoxItem Content="Activo" FontSize="14"/>
                                        <ComboBoxItem Content="Inactivo" FontSize="14"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Última operación desde -->
                                <StackPanel Grid.Column="4" Margin="8,0,8,0">
                                    <TextBlock Text="Última operación desde"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="#666" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding FiltroUltimaOperacionDesde, Mode=TwoWay}"
                                             Watermark="dd/MM/yyyy"
                                             MaxLength="10"
                                             FontSize="14"/>
                                </StackPanel>

                                <!-- Última conexión desde -->
                                <StackPanel Grid.Column="5" Margin="8,0,0,0">
                                    <TextBlock Text="Última conexión desde"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="#666" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding FiltroUltimaConexionDesde, Mode=TwoWay}"
                                             Watermark="dd/MM/yyyy"
                                             MaxLength="10"
                                             FontSize="14"/>
                                </StackPanel>
                            </Grid>

                            <!-- Fila inferior: Totales pequeños a la izquierda, Botones a la derecha -->
                            <Grid ColumnDefinitions="Auto,*">
                                <!-- Totales pequeños + Exportar -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                    <TextBlock FontSize="11" Foreground="#666" VerticalAlignment="Center">
                                        <Run Text="Activos:" FontWeight="SemiBold"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding UsuariosActivos}" FontWeight="Bold" Foreground="#003366"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="#666" VerticalAlignment="Center">
                                        <Run Text="Inactivos:" FontWeight="SemiBold"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding UsuariosInactivos}" FontWeight="Bold" Foreground="#FFC600"/>
                                    </TextBlock>
                                    <!-- Botón Exportar datos (amarillo pastel) -->
                                    <Button Classes="btn-export"
                                            Command="{Binding ExportarUsuariosExcelCommand}"
                                            VerticalAlignment="Center"
                                            ToolTip.Tip="Exportar datos a Excel">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <PathIcon Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20M12,19L8,15H10.5V12H13.5V15H16L12,19Z"
                                                      Width="14" Height="14" Foreground="#5c4a00"/>
                                            <TextBlock Text="Exportar datos" FontSize="13" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <!-- Botones: Nuevo, Limpiar, Buscar a la derecha -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                    <Button Classes="btn-primary"
                                            Padding="12,8"
                                            Command="{Binding MostrarFormularioCrearCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="+" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <TextBlock Text="NUEVO USUARIO" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Classes="btn-secondary"
                                            Padding="12,8"
                                            Command="{Binding LimpiarFiltrosCommand}">
                                        <TextBlock Text="LIMPIAR" FontSize="13" FontWeight="SemiBold"/>
                                    </Button>

                                    <Button Classes="btn-primary"
                                            Padding="12,8"
                                            Command="{Binding AplicarFiltrosCommand}">
                                        <TextBlock Text="BUSCAR" FontSize="13" FontWeight="SemiBold"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- LISTA DE USUARIOS -->
                    <ItemsControl ItemsSource="{Binding UsuariosFiltrados}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="usuario-card">
                                    <Grid ColumnDefinitions="*,Auto">

                                        <!-- Contenido principal -->
                                        <StackPanel Grid.Column="0" Spacing="12">

                                            <!-- Fila 1: Número de usuario y Nombre -->
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding NumeroUsuario}"
                                                           FontSize="16" FontWeight="Bold"
                                                           Foreground="#0b5394"/>
                                                <TextBlock Text="{Binding NombreCompleto}"
                                                           FontSize="14" Foreground="#595959"/>
                                            </StackPanel>

                                            <!-- Fila 2: Tres columnas - Contacto, Actividad, Comercio -->
                                            <Grid ColumnDefinitions="*,*,*">

                                                <!-- Columna 1: Contacto -->
                                                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,20,0">
                                                    <TextBlock Text="Contacto"
                                                               FontSize="14" FontWeight="Bold"
                                                               Foreground="#0b5394"/>
                                                    <Border Background="#ffd966" Height="2" Width="100" HorizontalAlignment="Left" Margin="0,2,0,6"/>
                                                    <TextBlock FontSize="13" Foreground="#595959">
                                                        <Run Text="Móvil:" FontWeight="SemiBold" Foreground="#0b5394"/>
                                                        <Run Text=" "/>
                                                        <Run Text="{Binding Telefono}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="13" Foreground="#595959">
                                                        <Run Text="Email:" FontWeight="SemiBold" Foreground="#0b5394"/>
                                                        <Run Text=" "/>
                                                        <Run Text="{Binding Correo}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Columna 2: Actividad -->
                                                <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,20,0">
                                                    <TextBlock Text="Actividad"
                                                               FontSize="14" FontWeight="Bold"
                                                               Foreground="#0b5394"/>
                                                    <Border Background="#ffd966" Height="2" Width="100" HorizontalAlignment="Left" Margin="0,2,0,6"/>
                                                    <TextBlock FontSize="13" Foreground="#595959">
                                                        <Run Text="Última operación:" FontWeight="SemiBold" Foreground="#0b5394"/>
                                                        <Run Text=" "/>
                                                        <Run Text="{Binding UltimaOperacionTexto}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="13" Foreground="#595959">
                                                        <Run Text="Última conexión:" FontWeight="SemiBold" Foreground="#0b5394"/>
                                                        <Run Text=" "/>
                                                        <Run Text="{Binding UltimoAccesoTexto}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Columna 3: Comercio -->
                                                <StackPanel Grid.Column="2" Spacing="4">
                                                    <TextBlock Text="Comercio"
                                                               FontSize="14" FontWeight="Bold"
                                                               Foreground="#0b5394"/>
                                                    <Border Background="#ffd966" Height="2" Width="100" HorizontalAlignment="Left" Margin="0,2,0,6"/>
                                                    <TextBlock FontSize="13" Foreground="#595959">
                                                        <Run Text="Nombre:" FontWeight="SemiBold" Foreground="#0b5394"/>
                                                        <Run Text=" "/>
                                                        <Run Text="{Binding NombreComercioDisplay}"/>
                                                    </TextBlock>
                                                    <!-- Badge Código Local -->
                                                    <Border Background="#0b5394"
                                                            CornerRadius="4" Padding="12,6"
                                                            HorizontalAlignment="Left"
                                                            Margin="0,4,0,0">
                                                        <TextBlock Text="{Binding CodigoLocalDisplay}"
                                                                   FontSize="12" FontWeight="Bold"
                                                                   Foreground="White"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Columna de botones a la derecha -->
                                        <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="8"
                                                    VerticalAlignment="Center" Margin="20,0,0,0">

                                            <!-- Botón X Eliminar -->
                                            <Button Background="Transparent"
                                                    BorderThickness="2"
                                                    BorderBrush="#0b5394"
                                                    Width="40" Height="40"
                                                    CornerRadius="20"
                                                    Padding="0"
                                                    Cursor="Hand"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    ToolTip.Tip="Eliminar usuario"
                                                    Command="{Binding $parent[ItemsControl].((vm:ManageUsersViewModel)DataContext).EliminarUsuarioCommand}"
                                                    CommandParameter="{Binding}">
                                                <Canvas Width="16" Height="16">
                                                    <Line StartPoint="3,3" EndPoint="13,13" Stroke="#0b5394" StrokeThickness="2.5" StrokeLineCap="Round"/>
                                                    <Line StartPoint="13,3" EndPoint="3,13" Stroke="#0b5394" StrokeThickness="2.5" StrokeLineCap="Round"/>
                                                </Canvas>
                                            </Button>

                                            <!-- Botón Editar (círculo amarillo con lápiz) -->
                                            <Button Background="#ffd966"
                                                    BorderThickness="0"
                                                    Width="40" Height="40"
                                                    CornerRadius="20"
                                                    Padding="0"
                                                    Cursor="Hand"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    ToolTip.Tip="Editar usuario"
                                                    Command="{Binding $parent[ItemsControl].((vm:ManageUsersViewModel)DataContext).EditarUsuarioCommand}"
                                                    CommandParameter="{Binding}">
                                                <Canvas Width="20" Height="20">
                                                    <!-- Cuadrado/documento -->
                                                    <Rectangle Canvas.Left="2" Canvas.Top="6" Width="12" Height="12"
                                                               Fill="Transparent" Stroke="White" StrokeThickness="2" RadiusX="1" RadiusY="1"/>
                                                    <!-- Lápiz -->
                                                    <Line StartPoint="8,4" EndPoint="16,12" Stroke="White" StrokeThickness="2" StrokeLineCap="Round"/>
                                                    <Line StartPoint="14,6" EndPoint="18,2" Stroke="White" StrokeThickness="2" StrokeLineCap="Round"/>
                                                    <Ellipse Canvas.Left="16" Canvas.Top="0" Width="4" Height="4" Fill="White"/>
                                                </Canvas>
                                            </Button>

                                            <!-- Botón ON/OFF Toggle -->
                                            <Button Background="{Binding EstadoBotonColor}"
                                                    BorderThickness="0"
                                                    Width="40" Height="40"
                                                    CornerRadius="20"
                                                    Padding="0"
                                                    Cursor="Hand"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    ToolTip.Tip="{Binding EstadoBotonTexto}"
                                                    Command="{Binding $parent[ItemsControl].((vm:ManageUsersViewModel)DataContext).CambiarEstadoUsuarioCommand}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="{Binding EstadoToggleTexto}"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Mensaje cuando no hay usuarios -->
                    <Border IsVisible="{Binding !UsuariosFiltrados.Count}"
                            Background="#f8f9fa"
                            CornerRadius="10"
                            Padding="50"
                            MinHeight="220">
                        <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="No se encontraron usuarios"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="#666"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Intenta ajustar los filtros de búsqueda o crea un nuevo usuario"
                                       FontSize="15" Foreground="#999"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- PANEL LATERAL DERECHO - OVERLAY RESPONSIVO -->
            <Border IsVisible="{Binding MostrarPanelDerecho}"
                    Background="#80000000"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    ZIndex="100">
                <Grid HorizontalAlignment="Right" VerticalAlignment="Stretch">
                    <Border Background="White"
                            BorderThickness="1,0,0,0"
                            BorderBrush="#e0e0e0"
                            MinWidth="500"
                            MaxWidth="650"
                            Width="580"
                            VerticalAlignment="Stretch">

                        <Grid RowDefinitions="Auto,*,Auto">

                            <!-- Header del panel -->
                            <Border Grid.Row="0" Background="#0b5394" Padding="24,20">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding TituloPanelDerecho}"
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding CerrarPanelDerechoCommand}"
                                            Cursor="Hand"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="X" FontSize="18" Foreground="White" FontWeight="Bold"/>
                                    </Button>
                                </Grid>
                            </Border>

                    <!-- Contenido del panel -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Panel>

                        <!-- FORMULARIO DE CREAR/EDITAR USUARIO -->
                        <StackPanel IsVisible="{Binding MostrarFormulario}" Margin="24" Spacing="20">

                            <!-- Información Personal -->
                            <Border Background="#f8f9fa" CornerRadius="8" Padding="20">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Información Personal"
                                               FontSize="17" FontWeight="Bold"
                                               Foreground="#0b5394"/>

                                    <!-- Nombre y Segundo Nombre -->
                                    <Grid ColumnDefinitions="*,*">
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Nombre *"
                                                       FontSize="13" FontWeight="Bold"
                                                       Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding FormNombre}"
                                                     Watermark="Primer nombre..."/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="Segundo Nombre"
                                                       FontSize="13" FontWeight="Bold"
                                                       Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding FormSegundoNombre}"
                                                     Watermark="Segundo nombre (opcional)..."/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Apellidos -->
                                    <Grid ColumnDefinitions="*,*">
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Primer Apellido *"
                                                       FontSize="13" FontWeight="Bold"
                                                       Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding FormApellidos}"
                                                     Watermark="Primer apellido..."/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="Segundo Apellido"
                                                       FontSize="13" FontWeight="Bold"
                                                       Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding FormSegundoApellido}"
                                                     Watermark="Segundo apellido (opcional)..."/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Número de Usuario -->
                                    <StackPanel>
                                        <TextBlock Text="Número de Usuario (generado automáticamente)"
                                                   FontSize="13" FontWeight="Bold"
                                                   Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding FormNumeroUsuario}"
                                                 IsReadOnly="True"
                                                 Background="#e9ecef"
                                                 Watermark="Se genera automáticamente..."/>
                                    </StackPanel>

                                    <!-- Correo y Teléfono -->
                                    <Grid ColumnDefinitions="*,*">
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Correo Electrónico *"
                                                       FontSize="13" FontWeight="Bold"
                                                       Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding FormCorreo}"
                                                     Watermark="usuario@ejemplo.com"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="Móvil"
                                                       FontSize="13" FontWeight="Bold"
                                                       Margin="0,0,0,6"/>
                                            <TextBox x:Name="TxtTelefono"
                                                     Text="{Binding FormTelefono}"
                                                     Watermark="600.000.000"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Contraseña (CREAR) -->
                                    <StackPanel IsVisible="{Binding !ModoEdicion}">
                                        <TextBlock Text="Contraseña *"
                                                   FontSize="13" FontWeight="Bold"
                                                   Margin="0,0,0,6"/>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding FormPassword}"
                                                     Watermark="Contraseña del usuario"
                                                     Margin="0,0,8,0"/>
                                            <Button Grid.Column="1"
                                                    Classes="btn-primary"
                                                    Command="{Binding GenerarPasswordCommand}"
                                                    MinWidth="130">
                                                <TextBlock Text="Generar" FontSize="13"/>
                                            </Button>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Contraseña (EDITAR) -->
                                    <StackPanel IsVisible="{Binding ModoEdicion}">
                                        <TextBlock Text="Cambiar Contraseña"
                                                   FontSize="13" FontWeight="Bold"
                                                   Margin="0,0,0,6"/>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding FormPassword}"
                                                     Watermark="Nueva contraseña (vacío = mantener)"
                                                     Margin="0,0,8,0"/>
                                            <Button Grid.Column="1"
                                                    Classes="btn-primary"
                                                    Command="{Binding GenerarPasswordCommand}"
                                                    MinWidth="130">
                                                <TextBlock Text="Generar Nueva" FontSize="13"/>
                                            </Button>
                                        </Grid>
                                        <TextBlock Text="Deja vacío si no deseas cambiar la contraseña"
                                                   FontSize="12" Foreground="#666" FontStyle="Italic" Margin="0,6,0,0"/>
                                    </StackPanel>

                                    <!-- Estado Activo -->
                                    <CheckBox IsChecked="{Binding FormActivo}"
                                              Content="Usuario Activo"
                                              FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <!-- Asignación de Locales -->
                            <Border Background="#e8f4f8" CornerRadius="8" Padding="20">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Asignación de Locales"
                                               FontSize="17" FontWeight="Bold"
                                               Foreground="#0b5394"/>

                                    <TextBlock Text="Busca y asigna los locales donde este usuario podrá trabajar"
                                               FontSize="14" Foreground="#666"
                                               TextWrapping="Wrap"/>

                                    <!-- Búsqueda -->
                                    <StackPanel>
                                        <TextBlock Text="Buscar por nombre de comercio"
                                                   FontSize="13" FontWeight="Bold"
                                                   Margin="0,0,0,6"/>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding BusquedaComercio}"
                                                     Watermark="Nombre del comercio..."
                                                     Margin="0,0,8,0"/>

                                            <Button Grid.Column="1"
                                                    Classes="btn-primary"
                                                    Command="{Binding BuscarLocalesPorComercioCommand}"
                                                    MinWidth="100">
                                                <TextBlock Text="Buscar" FontSize="13"/>
                                            </Button>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Resultados de búsqueda -->
                                    <Border IsVisible="{Binding MostrarResultadosBusqueda}"
                                            Background="White"
                                            BorderBrush="#0b5394"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel>
                                            <ScrollViewer MaxHeight="200">
                                                <ItemsControl ItemsSource="{Binding ResultadosBusquedaLocales}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderThickness="0,0,0,1"
                                                                    BorderBrush="#f0f0f0"
                                                                    Padding="12"
                                                                    Background="{Binding EstaSeleccionado, Converter={StaticResource BoolToBackgroundConverter}}">
                                                                <Grid ColumnDefinitions="Auto,*">
                                                                    <CheckBox Grid.Column="0"
                                                                              IsChecked="{Binding EstaSeleccionado}"
                                                                              VerticalAlignment="Center"
                                                                              Margin="0,0,12,0"/>
                                                                    <StackPanel Grid.Column="1" Spacing="3">
                                                                        <TextBlock Text="{Binding CodigoLocal}"
                                                                                   FontSize="14"
                                                                                   FontWeight="Bold"
                                                                                   Foreground="#0b5394"/>
                                                                        <TextBlock Text="{Binding NombreLocal}"
                                                                                   FontSize="13"
                                                                                   Foreground="#333"/>
                                                                        <TextBlock Text="{Binding DireccionCompleta}"
                                                                                   FontSize="12"
                                                                                   Foreground="#666"
                                                                                   TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                            <Border Background="#f8f9fa" Padding="12" BorderThickness="0,1,0,0" BorderBrush="#e0e0e0">
                                                <Grid ColumnDefinitions="*,Auto,Auto">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding ContadorSeleccionados}"
                                                               FontSize="13"
                                                               Foreground="#666"
                                                               VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1"
                                                            Classes="btn-secondary"
                                                            Command="{Binding CerrarBusquedaLocalesCommand}"
                                                            Margin="0,0,8,0"
                                                            Padding="12,6">
                                                        <TextBlock Text="Cancelar" FontSize="12"/>
                                                    </Button>
                                                    <Button Grid.Column="2"
                                                            Classes="btn-primary"
                                                            Command="{Binding AgregarLocalesSeleccionadosCommand}"
                                                            Padding="12,6">
                                                        <TextBlock Text="Agregar Seleccionados" FontSize="12"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Tipo de empleado -->
                                    <Border Background="White"
                                            CornerRadius="6"
                                            Padding="14"
                                            BorderThickness="1"
                                            BorderBrush="#0b5394">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Tipo de empleado:"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="#333"/>
                                            <TextBlock Text="{Binding TipoEmpleadoTexto}"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="#0b5394"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Locales asignados -->
                                    <StackPanel IsVisible="{Binding LocalesAsignados.Count}" Spacing="10">
                                        <TextBlock Text="Locales Asignados:"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="#0b5394"/>

                                        <ItemsControl ItemsSource="{Binding LocalesAsignados}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="White"
                                                            BorderBrush="#0b5394"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="14"
                                                            Margin="0,0,0,8">
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <StackPanel Grid.Column="0" Spacing="3">
                                                                <TextBlock Text="{Binding CodigoLocal}"
                                                                           FontSize="14"
                                                                           FontWeight="Bold"
                                                                           Foreground="#0b5394"/>
                                                                <TextBlock Text="{Binding NombreLocal}"
                                                                           FontSize="13"
                                                                           Foreground="#333"/>
                                                                <TextBlock Text="{Binding DireccionCompleta}"
                                                                           FontSize="12"
                                                                           Foreground="#666"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>

                                                            <Button Grid.Column="1"
                                                                    Background="#dc3545"
                                                                    Foreground="White"
                                                                    FontSize="12"
                                                                    FontWeight="Bold"
                                                                    Padding="12,6"
                                                                    CornerRadius="5"
                                                                    BorderThickness="0"
                                                                    VerticalAlignment="Center"
                                                                    Command="{Binding $parent[ItemsControl].((vm:ManageUsersViewModel)DataContext).QuitarLocalAsignadoCommand}"
                                                                    CommandParameter="{Binding}">
                                                                <TextBlock Text="Quitar"/>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- Mensaje si no hay locales -->
                                    <Border IsVisible="{Binding !LocalesAsignados.Count}"
                                            Background="White"
                                            CornerRadius="6"
                                            Padding="24"
                                            BorderThickness="1"
                                            BorderBrush="#ddd">
                                        <TextBlock Text="No hay locales asignados. Busca y selecciona al menos un local."
                                                   FontSize="13" Foreground="#666"
                                                   TextWrapping="Wrap"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <!-- VER DETALLES DEL USUARIO -->
                        <StackPanel IsVisible="{Binding !MostrarFormulario}" Margin="24" Spacing="20">

                            <!-- Información General -->
                            <Border Background="#f8f9fa" CornerRadius="8" Padding="20">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Información General"
                                               FontSize="17" FontWeight="Bold"
                                               Foreground="#0b5394"/>

                                    <StackPanel Spacing="12">
                                        <Grid ColumnDefinitions="150,*">
                                            <TextBlock Grid.Column="0" Text="Nombre Completo:"
                                                       FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding UsuarioSeleccionado.NombreCompleto}"
                                                       FontSize="14"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="150,*">
                                            <TextBlock Grid.Column="0" Text="Número Usuario:"
                                                       FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding UsuarioSeleccionado.NumeroUsuario}"
                                                       FontSize="14"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="150,*">
                                            <TextBlock Grid.Column="0" Text="Correo:"
                                                       FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding UsuarioSeleccionado.Correo}"
                                                       FontSize="14"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="150,*">
                                            <TextBlock Grid.Column="0" Text="Móvil:"
                                                       FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding UsuarioSeleccionado.Telefono}"
                                                       FontSize="14"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="150,*">
                                            <TextBlock Grid.Column="0" Text="Tipo:"
                                                       FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding UsuarioSeleccionado.TipoUsuarioDisplay}"
                                                       FontSize="14"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="150,*">
                                            <TextBlock Grid.Column="0" Text="Último Acceso:"
                                                       FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding UsuarioSeleccionado.UltimoAccesoTexto}"
                                                       FontSize="14"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="150,*">
                                            <TextBlock Grid.Column="0" Text="Estado:"
                                                       FontWeight="SemiBold" FontSize="14"
                                                       VerticalAlignment="Center"/>
                                            <Border Grid.Column="1"
                                                    Background="{Binding UsuarioSeleccionado.EstadoColor}"
                                                    CornerRadius="5"
                                                    Padding="12,5"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding UsuarioSeleccionado.EstadoTexto}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="13"/>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Locales Asignados -->
                            <Border Background="#e8f4f8" CornerRadius="8" Padding="20">
                                <StackPanel Spacing="14">
                                    <TextBlock Text="Locales Asignados"
                                               FontSize="17" FontWeight="Bold"
                                               Foreground="#0b5394"/>

                                    <ItemsControl ItemsSource="{Binding LocalesAsignados}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White"
                                                        CornerRadius="6"
                                                        Padding="16"
                                                        Margin="0,0,0,10"
                                                        BorderThickness="1"
                                                        BorderBrush="#0b5394">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="{Binding CodigoLocal}"
                                                                   FontSize="15"
                                                                   FontWeight="Bold"
                                                                   Foreground="#0b5394"/>
                                                        <TextBlock Text="{Binding NombreLocal}"
                                                                   FontSize="14"
                                                                   Foreground="#333"
                                                                   FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding DireccionCompleta}"
                                                                   FontSize="13"
                                                                   Foreground="#666"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Boton cerrar al final del panel de informacion -->
                            <Button Classes="btn-secondary"
                                    Command="{Binding CerrarPanelDerechoCommand}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,20,0,0">
                                <TextBlock Text="CERRAR" FontSize="13" FontWeight="Bold"/>
                            </Button>
                        </StackPanel>
                    </Panel>
                    </ScrollViewer>

                    <!-- Footer con botones -->
                    <Border Grid.Row="2"
                            IsVisible="{Binding MostrarFormulario}"
                            Background="#f8f9fa"
                            BorderThickness="0,1,0,0"
                            BorderBrush="#e0e0e0"
                            Padding="24,16">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <Button Grid.Column="1"
                                    Classes="btn-secondary"
                                    Command="{Binding CerrarPanelDerechoCommand}"
                                    Margin="0,0,12,0"
                                    MinWidth="110">
                                <TextBlock Text="Cancelar" FontSize="14"/>
                            </Button>
                            <Button Grid.Column="2"
                                    Classes="btn-primary"
                                    Command="{Binding GuardarUsuarioCommand}"
                                    MinWidth="160">
                                <TextBlock Text="{Binding BotonGuardarTexto}" FontSize="14"/>
                            </Button>
                        </Grid>
                    </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- VENTANA DE CONFIRMACIÓN PARA ELIMINAR USUARIO -->
        <Border Grid.Row="1"
                IsVisible="{Binding MostrarDialogoConfirmacion}"
                Background="#80000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ZIndex="1001">
            <Border Background="White"
                    CornerRadius="10"
                    Padding="28"
                    MaxWidth="500"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BoxShadow="0 8 24 0 #40000000">
                <StackPanel Spacing="20">
                    <TextBlock Text="CONFIRMAR ELIMINACIÓN"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#dc3545"
                               HorizontalAlignment="Center"/>

                    <StackPanel Spacing="14">
                        <TextBlock Text="¿Estás seguro de que deseas eliminar este usuario?"
                                   FontSize="15"
                                   Foreground="#333"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"/>

                        <Border Background="#fff3cd"
                                BorderThickness="1"
                                BorderBrush="#ffc107"
                                CornerRadius="6"
                                Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Usuario a eliminar:"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#856404"/>
                                <TextBlock Text="{Binding UsuarioSeleccionado.NombreCompleto}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#003366"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding UsuarioSeleccionado.NumeroUsuario}"
                                           FontSize="14"
                                           Foreground="#666"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#f8d7da"
                                BorderThickness="1"
                                BorderBrush="#dc3545"
                                CornerRadius="6"
                                Padding="14">
                            <TextBlock FontSize="13"
                                       Foreground="#721c24"
                                       TextWrapping="Wrap">
                                <Run Text="ADVERTENCIA:" FontWeight="Bold"/>
                                <Run Text=" Esta acción NO se puede deshacer. Se eliminarán todos los datos del usuario."/>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,*">
                        <Button Grid.Column="0"
                                Classes="btn-secondary"
                                Command="{Binding CancelarEliminarUsuarioCommand}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,8,0">
                            <TextBlock Text="CANCELAR" FontSize="14" FontWeight="Bold"/>
                        </Button>
                        <Button Grid.Column="1"
                                Classes="btn-danger"
                                Command="{Binding ConfirmarEliminarUsuarioCommand}"
                                HorizontalAlignment="Stretch"
                                Margin="8,0,0,0">
                            <TextBlock Text="SÍ, ELIMINAR" FontSize="14" FontWeight="Bold"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- INDICADOR DE CARGA -->
        <Border IsVisible="{Binding Cargando}"
                Background="#80000000"
                Grid.Row="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ZIndex="1000">
            <Border Background="White"
                    CornerRadius="12"
                    Padding="45"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BoxShadow="0 8 24 0 #40000000">
                <StackPanel Spacing="18" HorizontalAlignment="Center">
                    <TextBlock Text="Procesando..."
                               FontSize="20" FontWeight="Bold"
                               Foreground="#0b5394"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Por favor espere..."
                               FontSize="15" Foreground="#666"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- NOTIFICACIÓN DE ÉXITO/ERROR -->
        <Border IsVisible="{Binding MostrarMensajeExito}"
                Background="{Binding MensajeExitoColor}"
                CornerRadius="8"
                Padding="24,16"
                Margin="28"
                BoxShadow="0 4 12 0 #40000000"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Grid.Row="1"
                ZIndex="1002">
            <TextBlock Text="{Binding MensajeExito}"
                       FontSize="15" FontWeight="Bold"
                       Foreground="White"
                       TextWrapping="Wrap"
                       MaxWidth="650"
                       TextAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
