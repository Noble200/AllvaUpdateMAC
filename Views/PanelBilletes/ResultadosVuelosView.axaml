<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Allva.Desktop.ViewModels"
             xmlns:models="using:Allva.Desktop.Models"
             x:Class="Allva.Desktop.Views.PanelBilletes.ResultadosVuelosView"
             x:DataType="vm:FlightTicketsViewModel"
             x:Name="ResultadosRoot">

    <UserControl.Styles>
        <Style Selector="Border.skeleton">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="INFINITE" PlaybackDirection="Alternate">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.3"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.7"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Border.spinner">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Style.Animations>
                <Animation Duration="0:0:0.8" IterationCount="INFINITE">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="360"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Button.btn-continuar">
            <Setter Property="Background" Value="#0b5394"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="40,12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.btn-continuar:pointerover">
            <Setter Property="Background" Value="#084171"/>
        </Style>
        <Style Selector="Button.btn-continuar:disabled">
            <Setter Property="Background" Value="#7BAAD4"/>
            <Setter Property="Foreground" Value="#DDDDDD"/>
        </Style>

        <Style Selector="Button.btn-volver">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0b5394"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#0b5394"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="Button.btn-volver:pointerover">
            <Setter Property="Background" Value="#E8F0FE"/>
        </Style>

        <Style Selector="Border.vuelo-card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style Selector="Button.btn-clase">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.btn-clase:pointerover">
            <Setter Property="BorderBrush" Value="#0b5394"/>
            <Setter Property="Background" Value="#F0F5FF"/>
        </Style>
    </UserControl.Styles>

    <Border Background="#FFD966" Padding="0">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="14" Margin="40,20" HorizontalAlignment="Center" MaxWidth="1100">

        <!-- Titulo -->
        <Border Background="White" CornerRadius="8" Padding="20,16" BoxShadow="0 2 8 0 #20000000">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                <TextBlock Text="VUELO IDA  -" FontSize="22" FontWeight="Bold"
                           Foreground="#0b5394" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TituloResultadosIda}" FontSize="22" FontWeight="Bold"
                           Foreground="#FFC600" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- SKELETON LOADING -->
        <Border Background="White" CornerRadius="8" Padding="20" BoxShadow="0 2 8 0 #20000000"
                IsVisible="{Binding CargandoVuelos}">
            <Grid>
                <StackPanel Spacing="12" Opacity="0.5">
                    <Border Classes="skeleton" Background="#F0F0F0" CornerRadius="8" Height="110"/>
                    <Border Classes="skeleton" Background="#F0F0F0" CornerRadius="8" Height="110"/>
                    <Border Classes="skeleton" Background="#F0F0F0" CornerRadius="8" Height="110"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                    <Border Classes="spinner" Width="40" Height="40"
                            BorderBrush="#0b5394" BorderThickness="4,4,4,0"
                            CornerRadius="20" Background="Transparent"
                            HorizontalAlignment="Center">
                        <Border.RenderTransform>
                            <RotateTransform/>
                        </Border.RenderTransform>
                    </Border>
                    <TextBlock Text="Buscando vuelos..."
                               Foreground="#0b5394" FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LISTA DE VUELOS -->
        <Border Background="White" CornerRadius="8" Padding="20" BoxShadow="0 2 8 0 #20000000"
                IsVisible="{Binding !CargandoVuelos}">
            <StackPanel Spacing="12">
                <ItemsControl ItemsSource="{Binding VuelosDisponibles}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="12"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:VueloItem">
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="20,16">
                                <!-- Indicador de seleccion -->
                                <Panel>
                                    <Border CornerRadius="8" BorderBrush="#0b5394" BorderThickness="2.5"
                                            IsVisible="{Binding EstaSeleccionado}" Margin="-20,-16"/>

                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <!-- INFO VUELO -->
                                        <StackPanel Grid.Column="0" Spacing="6" MinWidth="420">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding HoraSalida}" FontSize="22" FontWeight="Bold" Foreground="#0b5394"/>
                                                    <TextBlock Text="{Binding OrigenCodigo}" FontSize="12" Foreground="#999999"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Text="{Binding TextoEscalasCorto}" FontSize="10" Foreground="#666666" HorizontalAlignment="Center"/>
                                                    <Border Height="1" Background="#CCCCCC" MinWidth="120"/>
                                                    <TextBlock Text="&#x2192;" FontSize="14" Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding HoraLlegada}" FontSize="22" FontWeight="Bold" Foreground="#0b5394"/>
                                                    <TextBlock Text="{Binding DestinoCodigo}" FontSize="12" Foreground="#999999"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="{Binding OperadoPorTexto}" FontSize="12" Foreground="#666666" FontStyle="Italic"/>
                                        </StackPanel>

                                        <!-- SEPARADOR -->
                                        <Border Grid.Column="1" Width="1" Background="#E0E0E0" Margin="20,0" VerticalAlignment="Stretch"/>

                                        <!-- CLASES - Botones clickeables -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                            <!-- Turista -->
                                            <Panel>
                                                <Button Classes="btn-clase"
                                                        Command="{Binding #ResultadosRoot.((vm:FlightTicketsViewModel)DataContext).SeleccionarTuristaCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding DisponibleTurista}">
                                                    <StackPanel Spacing="2" HorizontalAlignment="Center">
                                                        <TextBlock Text="Turista" FontSize="12" FontWeight="Bold" Foreground="#0b5394" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding PrecioTuristaTexto}" FontSize="15" FontWeight="Bold"
                                                                   Foreground="#2E7D32" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <!-- Seleccion overlay -->
                                                <Border CornerRadius="8" BorderBrush="#0b5394" BorderThickness="2.5" Background="#10085394"
                                                        IsVisible="{Binding TuristaSeleccionada}" IsHitTestVisible="False"/>
                                                <TextBlock Text="&#x2713;" FontSize="12" FontWeight="Bold" Foreground="#0b5394"
                                                           HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0"
                                                           IsVisible="{Binding TuristaSeleccionada}"/>
                                            </Panel>

                                            <!-- Premium -->
                                            <Panel>
                                                <Button Classes="btn-clase"
                                                        Command="{Binding #ResultadosRoot.((vm:FlightTicketsViewModel)DataContext).SeleccionarPremiumCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding DisponiblePremium}">
                                                    <StackPanel Spacing="2" HorizontalAlignment="Center">
                                                        <TextBlock Text="Premium" FontSize="12" FontWeight="Bold" Foreground="#0b5394" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding PrecioPremiumTexto}" FontSize="15" FontWeight="Bold"
                                                                   Foreground="#0b5394" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Border CornerRadius="8" BorderBrush="#0b5394" BorderThickness="2.5" Background="#10085394"
                                                        IsVisible="{Binding PremiumSeleccionada}" IsHitTestVisible="False"/>
                                                <TextBlock Text="&#x2713;" FontSize="12" FontWeight="Bold" Foreground="#0b5394"
                                                           HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0"
                                                           IsVisible="{Binding PremiumSeleccionada}"/>
                                            </Panel>

                                            <!-- Business -->
                                            <Panel>
                                                <Button Classes="btn-clase"
                                                        Command="{Binding #ResultadosRoot.((vm:FlightTicketsViewModel)DataContext).SeleccionarBusinessCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding DisponibleBusiness}">
                                                    <StackPanel Spacing="2" HorizontalAlignment="Center">
                                                        <TextBlock Text="Business" FontSize="12" FontWeight="Bold" Foreground="#0b5394" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding PrecioBusinessTexto}" FontSize="15" FontWeight="Bold"
                                                                   Foreground="#0b5394" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Border CornerRadius="8" BorderBrush="#0b5394" BorderThickness="2.5" Background="#10085394"
                                                        IsVisible="{Binding BusinessSeleccionada}" IsHitTestVisible="False"/>
                                                <TextBlock Text="&#x2713;" FontSize="12" FontWeight="Bold" Foreground="#0b5394"
                                                           HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0"
                                                           IsVisible="{Binding BusinessSeleccionada}"/>
                                            </Panel>
                                        </StackPanel>
                                    </Grid>
                                </Panel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="No se encontraron vuelos para esta ruta"
                           FontSize="14" Foreground="#999999" FontStyle="Italic"
                           HorizontalAlignment="Center" Margin="0,20"
                           IsVisible="{Binding VuelosDisponibles.Count, Converter={StaticResource EqualToZeroConverter}}"/>
            </StackPanel>
        </Border>

        <!-- Disclaimer -->
        <TextBlock Text="*Los precios indicados corresponden al numero de pasajeros previamente seleccionado. Los horarios se muestran en la franja horaria de Espana (CET)."
                   FontSize="11" Foreground="#999999" FontStyle="Italic"
                   TextWrapping="Wrap" Margin="0,4"
                   IsVisible="{Binding !CargandoVuelos}"/>

        <!-- Botones -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16"
                    Margin="0,6,0,20" IsVisible="{Binding !CargandoVuelos}">
            <Button Classes="btn-volver" Content="&#x2190; Volver" Command="{Binding VolverACalendarioCommand}"/>
            <Button Classes="btn-continuar" Content="Seleccionar vuelo y continuar  &#x203A;" Command="{Binding IrADetalleCommand}"/>
        </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Border>

</UserControl>
