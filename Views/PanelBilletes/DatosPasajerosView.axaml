<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Allva.Desktop.ViewModels"
             xmlns:models="using:Allva.Desktop.Models"
             x:Class="Allva.Desktop.Views.PanelBilletes.DatosPasajerosView"
             x:DataType="vm:FlightTicketsViewModel">

    <UserControl.Styles>
        <Style Selector="Button.btn-continuar">
            <Setter Property="Background" Value="#0b5394"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="40,12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.btn-continuar:pointerover">
            <Setter Property="Background" Value="#084171"/>
        </Style>

        <Style Selector="Button.btn-volver">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0b5394"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#0b5394"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="Button.btn-volver:pointerover">
            <Setter Property="Background" Value="#E8F0FE"/>
        </Style>

        <Style Selector="TextBox.form-field">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Height" Value="38"/>
        </Style>
    </UserControl.Styles>

    <Border Background="#FFD966" Padding="0">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="14" Margin="20">

        <!-- TITULO + STEPPER -->
        <Border Background="White" CornerRadius="8" Padding="20,16" BoxShadow="0 2 8 0 #20000000">
            <StackPanel Spacing="16">
                <TextBlock Text="{Binding TituloRutaBusqueda}" FontSize="22" FontWeight="Bold"
                           Foreground="#0b5394" HorizontalAlignment="Center"/>

                <!-- ============ STEPPER ============ -->
                <Border HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="0">
                        <StackPanel Spacing="4" HorizontalAlignment="Center" Width="120">
                            <Ellipse Width="30" Height="30" Fill="#0b5394" HorizontalAlignment="Center"/>
                            <TextBlock Text="&#x2713;" FontSize="14" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" Margin="0,-27,0,0"/>
                            <TextBlock Text="Vuelos" FontSize="12" Foreground="#0b5394"
                                       HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,10,0,0"/>
                        </StackPanel>
                        <Border Width="60" Height="2" Background="#0b5394" VerticalAlignment="Top" Margin="0,15,0,0"/>
                        <StackPanel Spacing="4" HorizontalAlignment="Center" Width="120">
                            <Ellipse Width="30" Height="30" Fill="#0b5394" HorizontalAlignment="Center"/>
                            <TextBlock Text="&#x2713;" FontSize="14" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" Margin="0,-27,0,0"/>
                            <TextBlock Text="Extras" FontSize="12" Foreground="#0b5394"
                                       HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,10,0,0"/>
                        </StackPanel>
                        <Border Width="60" Height="2" Background="#0b5394" VerticalAlignment="Top" Margin="0,15,0,0"/>
                        <StackPanel Spacing="4" HorizontalAlignment="Center" Width="120">
                            <Ellipse Width="30" Height="30" Fill="#FFC600" HorizontalAlignment="Center"/>
                            <TextBlock Text="3" FontSize="14" FontWeight="Bold" Foreground="#0b5394"
                                       HorizontalAlignment="Center" Margin="0,-27,0,0"/>
                            <TextBlock Text="Datos" FontSize="12" Foreground="#0b5394"
                                       HorizontalAlignment="Center" FontWeight="Bold" Margin="0,10,0,0"/>
                        </StackPanel>
                        <Border Width="60" Height="2" Background="#CCCCCC" VerticalAlignment="Top" Margin="0,15,0,0"/>
                        <StackPanel Spacing="4" HorizontalAlignment="Center" Width="120">
                            <Ellipse Width="30" Height="30" Fill="#CCCCCC" HorizontalAlignment="Center"/>
                            <TextBlock Text="4" FontSize="14" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" Margin="0,-27,0,0"/>
                            <TextBlock Text="Pagos" FontSize="12" Foreground="#999999"
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ============ CONTENIDO: Formularios + Sidebar ============ -->
        <Grid ColumnDefinitions="*,14,340">

            <!-- FORMULARIOS DE PASAJEROS -->
            <StackPanel Grid.Column="0" Spacing="14">
                <Border Background="White" CornerRadius="8" Padding="20,16" BoxShadow="0 2 8 0 #20000000">
                    <TextBlock Text="Datos de pasajeros" FontSize="18" FontWeight="Bold" Foreground="#0b5394"/>
                </Border>

                <ItemsControl ItemsSource="{Binding Pasajeros}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="14"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:PasajeroItem">
                            <Border Background="White" CornerRadius="8" Padding="24" BoxShadow="0 2 8 0 #20000000">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="{Binding TituloFormulario}" FontSize="15" FontWeight="Bold" Foreground="#0b5394"/>

                                    <Grid ColumnDefinitions="120,16,*">
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="Tratamiento" FontSize="11" Foreground="#666666" FontWeight="SemiBold"/>
                                            <ComboBox SelectedItem="{Binding Tratamiento}" Height="38" FontSize="13" HorizontalAlignment="Stretch">
                                                <ComboBoxItem Content="Sr."/>
                                                <ComboBoxItem Content="Sra."/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="4">
                                            <TextBlock Text="Nombre*" FontSize="11" Foreground="#666666" FontWeight="SemiBold"/>
                                            <TextBox Classes="form-field" Text="{Binding Nombre, Mode=TwoWay}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,16,*">
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="Apellidos*" FontSize="11" Foreground="#666666" FontWeight="SemiBold"/>
                                            <TextBox Classes="form-field" Text="{Binding Apellidos, Mode=TwoWay}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="4">
                                            <TextBlock Text="Fecha de nacimiento*" FontSize="11" Foreground="#666666" FontWeight="SemiBold"/>
                                            <DatePicker SelectedDate="{Binding FechaNacimiento}" HorizontalAlignment="Stretch"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,16,120,8,*">
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="Nacionalidad*" FontSize="11" Foreground="#666666" FontWeight="SemiBold"/>
                                            <TextBox Classes="form-field" Text="{Binding Nacionalidad, Mode=TwoWay}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="4">
                                            <TextBlock Text="Documento*" FontSize="11" Foreground="#666666" FontWeight="SemiBold"/>
                                            <ComboBox SelectedItem="{Binding TipoDocumento}" Height="38" FontSize="13" HorizontalAlignment="Stretch">
                                                <ComboBoxItem Content="Pasaporte"/>
                                                <ComboBoxItem Content="DNI"/>
                                                <ComboBoxItem Content="NIE"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="4" Spacing="4">
                                            <TextBlock Text="n pasaporte" FontSize="11" Foreground="#666666" FontWeight="SemiBold"/>
                                            <TextBox Classes="form-field" Text="{Binding NumeroDocumento, Mode=TwoWay}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,16,*">
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="Caducidad documento*" FontSize="11" Foreground="#666666" FontWeight="SemiBold"/>
                                            <DatePicker SelectedDate="{Binding CaducidadDocumento}" HorizontalAlignment="Stretch"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="4">
                                            <TextBlock Text="Telefono*" FontSize="11" Foreground="#666666" FontWeight="SemiBold"/>
                                            <TextBox Classes="form-field" Text="{Binding Telefono, Mode=TwoWay}"/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="E-mail*" FontSize="11" Foreground="#666666" FontWeight="SemiBold"/>
                                        <TextBox Classes="form-field" Text="{Binding Email, Mode=TwoWay}" Width="300" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- ============ SIDEBAR ============ -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="24"
                    BoxShadow="0 2 8 0 #20000000" BorderBrush="#0b5394" BorderThickness="1"
                    VerticalAlignment="Top">
                <StackPanel Spacing="14">
                    <TextBlock Text="Resumen de la reserva" FontSize="16" FontWeight="Bold" Foreground="#0b5394"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#x1F464;" FontSize="16"/>
                        <TextBlock Text="{Binding ResumenPasajeros}" FontSize="13" Foreground="#333333" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Height="1" Background="#E0E0E0"/>

                    <TextBlock Text="Resumen de vuelo" FontSize="14" FontWeight="Bold" Foreground="#0b5394"/>

                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#x1F4C5;" FontSize="13"/>
                            <TextBlock Text="{Binding ResumenVueloIda}" FontSize="12" Foreground="#666666" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="4" IsVisible="{Binding TieneVueloVueltaSeleccionado}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#x1F4C5;" FontSize="13"/>
                            <TextBlock Text="{Binding ResumenVueloVuelta}" FontSize="12" Foreground="#666666" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="#E0E0E0"/>

                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Precio billetes:" FontSize="12" Foreground="#333333"/>
                            <TextBlock Grid.Column="1" Text="{Binding PrecioBilletesTexto}" FontSize="12" Foreground="#333333" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Equipaje facturado:" FontSize="12" Foreground="#333333"/>
                            <TextBlock Grid.Column="1" Text="{Binding PrecioEquipajeTexto}" FontSize="12" Foreground="#333333"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Sentarse juntos:" FontSize="12" Foreground="#333333"/>
                            <TextBlock Grid.Column="1" Text="{Binding PrecioSentarseJuntosResumenTexto}" FontSize="12" Foreground="#333333"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding SeguroViaje}">
                            <TextBlock Grid.Column="0" Text="Seguro de viaje:" FontSize="12" Foreground="#333333"/>
                            <TextBlock Grid.Column="1" Text="{Binding PrecioSeguroTexto}" FontSize="12" Foreground="#333333"/>
                        </Grid>
                    </StackPanel>

                    <Border Height="1" Background="#0b5394"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Total:" FontSize="16" FontWeight="Bold" Foreground="#0b5394"/>
                        <TextBlock Grid.Column="1" Text="{Binding PrecioTotalTexto}" FontSize="20" FontWeight="Bold" Foreground="#0b5394"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Mensaje de error de validación -->
        <Border Background="#FFEBEE" CornerRadius="8" Padding="16" BoxShadow="0 2 8 0 #20000000"
                IsVisible="{Binding MostrarErrorDatos}">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="&#x26A0;" FontSize="16" Foreground="#C62828"/>
                    <TextBlock Text="Atención" FontSize="14" FontWeight="Bold" Foreground="#C62828" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding MensajeErrorDatos}" FontSize="12" Foreground="#C62828" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Botones -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Margin="0,6,0,20">
            <Button Classes="btn-volver" Content="&#x2190; Volver" Command="{Binding VolverAExtrasCommand}"/>
            <Button Classes="btn-continuar" Content="Continuar a Pagos  &#x203A;" Command="{Binding ContinuarAPagosCommand}"/>
        </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Border>

</UserControl>
