<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Allva.Desktop.ViewModels"
             x:Class="Allva.Desktop.Views.PanelBilletes.DetalleVueloView"
             x:DataType="vm:FlightTicketsViewModel">

    <UserControl.Styles>
        <Style Selector="Button.btn-continuar">
            <Setter Property="Background" Value="#0b5394"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="40,12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.btn-continuar:pointerover">
            <Setter Property="Background" Value="#084171"/>
        </Style>

        <Style Selector="Button.btn-volver">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0b5394"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#0b5394"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="Button.btn-volver:pointerover">
            <Setter Property="Background" Value="#E8F0FE"/>
        </Style>
    </UserControl.Styles>

    <Border Background="#FFD966" Padding="0">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="14" Margin="20">

        <!-- TITULO -->
        <Border Background="White" CornerRadius="8" Padding="20,16" BoxShadow="0 2 8 0 #20000000">
            <StackPanel Spacing="16">
                <TextBlock Text="{Binding TituloRutaBusqueda}" FontSize="22" FontWeight="Bold"
                           Foreground="#0b5394" HorizontalAlignment="Center"/>

                <!-- ============ STEPPER ============ -->
                <Border HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="0">
                        <StackPanel Spacing="4" HorizontalAlignment="Center" Width="120">
                            <Ellipse Width="30" Height="30" Fill="#0b5394" HorizontalAlignment="Center"/>
                            <TextBlock Text="1" FontSize="14" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" Margin="0,-27,0,0"/>
                            <TextBlock Text="Vuelos" FontSize="12" Foreground="#0b5394"
                                       HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,10,0,0"/>
                        </StackPanel>
                        <Border Width="60" Height="2" Background="#0b5394" VerticalAlignment="Top" Margin="0,15,0,0"/>
                        <StackPanel Spacing="4" HorizontalAlignment="Center" Width="120">
                            <Ellipse Width="30" Height="30" Fill="#CCCCCC" HorizontalAlignment="Center"/>
                            <TextBlock Text="2" FontSize="14" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" Margin="0,-27,0,0"/>
                            <TextBlock Text="Extras" FontSize="12" Foreground="#999999"
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        </StackPanel>
                        <Border Width="60" Height="2" Background="#CCCCCC" VerticalAlignment="Top" Margin="0,15,0,0"/>
                        <StackPanel Spacing="4" HorizontalAlignment="Center" Width="120">
                            <Ellipse Width="30" Height="30" Fill="#CCCCCC" HorizontalAlignment="Center"/>
                            <TextBlock Text="3" FontSize="14" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" Margin="0,-27,0,0"/>
                            <TextBlock Text="Datos" FontSize="12" Foreground="#999999"
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        </StackPanel>
                        <Border Width="60" Height="2" Background="#CCCCCC" VerticalAlignment="Top" Margin="0,15,0,0"/>
                        <StackPanel Spacing="4" HorizontalAlignment="Center" Width="120">
                            <Ellipse Width="30" Height="30" Fill="#CCCCCC" HorizontalAlignment="Center"/>
                            <TextBlock Text="4" FontSize="14" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" Margin="0,-27,0,0"/>
                            <TextBlock Text="Pagos" FontSize="12" Foreground="#999999"
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ============ CONTENIDO: Timeline + Sidebar ============ -->
        <Grid ColumnDefinitions="*,14,340">

            <!-- TIMELINE DEL VUELO -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="30"
                    BoxShadow="0 2 8 0 #20000000">
                <StackPanel Spacing="0">
                    <Border Background="#F5F5F5" CornerRadius="6" Padding="12,8" Margin="0,0,0,20"
                            HorizontalAlignment="Left">
                        <TextBlock Text="{Binding FechaIda, StringFormat='{}{0:ddd, dd MMM}'}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#333333"/>
                    </Border>

                    <!-- Origen -->
                    <Grid ColumnDefinitions="60,30,*">
                        <StackPanel Grid.Column="0" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding VueloIdaSeleccionado.OrigenCodigo}" FontSize="16" FontWeight="Bold" Foreground="#0b5394"/>
                            <TextBlock Text="{Binding VueloIdaSeleccionado.HoraSalida}" FontSize="13" Foreground="#666666"/>
                        </StackPanel>
                        <Canvas Grid.Column="1" Width="30" HorizontalAlignment="Center">
                            <Ellipse Width="12" Height="12" Fill="#0b5394" Canvas.Left="9" Canvas.Top="4"/>
                            <Border Width="2" Height="140" Background="#0b5394" Canvas.Left="14" Canvas.Top="16"/>
                        </Canvas>
                        <StackPanel Grid.Column="2" Spacing="4" Margin="10,0,0,0">
                            <TextBlock Text="{Binding VueloIdaSeleccionado.OrigenCiudad}" FontSize="16" FontWeight="Bold" Foreground="#333333"/>
                            <TextBlock Text="{Binding VueloIdaSeleccionado.OrigenAeropuerto}" FontSize="12" Foreground="#666666"/>
                            <TextBlock Text="{Binding VueloIdaSeleccionado.TerminalOrigen}" FontSize="12" Foreground="#666666"/>
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                <TextBlock Text="{Binding VueloIdaSeleccionado.NumeroVuelo}" FontSize="12" Foreground="#0b5394" FontWeight="SemiBold"/>
                                <TextBlock Text="&#x00B7;" FontSize="12" Foreground="#999999"/>
                                <TextBlock Text="{Binding VueloIdaSeleccionado.Aerolinea}" FontSize="12" Foreground="#0b5394" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding VueloIdaSeleccionado.Avion}" FontSize="11" Foreground="#999999"/>
                            <TextBlock FontSize="11" Foreground="#666666">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="Duracion: {0}">
                                        <Binding Path="VueloIdaSeleccionado.Duracion"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <!-- Destino -->
                    <Grid ColumnDefinitions="60,30,*" Margin="0,20,0,0">
                        <StackPanel Grid.Column="0" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding VueloIdaSeleccionado.DestinoCodigo}" FontSize="16" FontWeight="Bold" Foreground="#0b5394"/>
                            <TextBlock Text="{Binding VueloIdaSeleccionado.HoraLlegada}" FontSize="13" Foreground="#666666"/>
                        </StackPanel>
                        <Canvas Grid.Column="1" Width="30" HorizontalAlignment="Center">
                            <Ellipse Width="12" Height="12" Fill="#0b5394" Canvas.Left="9" Canvas.Top="4"/>
                        </Canvas>
                        <StackPanel Grid.Column="2" Spacing="2" Margin="10,0,0,0">
                            <TextBlock Text="{Binding VueloIdaSeleccionado.DestinoCiudad}" FontSize="16" FontWeight="Bold" Foreground="#333333"/>
                            <TextBlock Text="{Binding VueloIdaSeleccionado.DestinoAeropuerto}" FontSize="12" Foreground="#666666"/>
                            <TextBlock Text="{Binding VueloIdaSeleccionado.TerminalDestino}" FontSize="12" Foreground="#666666"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============ SIDEBAR ============ -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="24"
                    BoxShadow="0 2 8 0 #20000000" BorderBrush="#0b5394" BorderThickness="1"
                    VerticalAlignment="Top">
                <StackPanel Spacing="16">
                    <TextBlock Text="Resumen de la reserva" FontSize="16" FontWeight="Bold" Foreground="#0b5394"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#x1F464;" FontSize="16"/>
                        <TextBlock Text="{Binding ResumenPasajeros}" FontSize="13" Foreground="#333333" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Height="1" Background="#E0E0E0"/>

                    <TextBlock Text="Resumen de vuelo" FontSize="14" FontWeight="Bold" Foreground="#0b5394"/>

                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#x2708;" FontSize="14" Foreground="#0b5394"/>
                            <TextBlock Text="{Binding VueloIdaSeleccionado.RutaTexto}" FontSize="12" Foreground="#333333" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#x1F4C5;" FontSize="14"/>
                            <TextBlock Text="{Binding ResumenVueloIda}" FontSize="12" Foreground="#666666" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="#E0E0E0"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Precio ida:" FontSize="13" FontWeight="Bold" Foreground="#0b5394"/>
                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                            <TextBlock Text="Total:" FontSize="14" Foreground="#0b5394" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding PrecioBilletesTexto}" FontSize="18" FontWeight="Bold" Foreground="#0b5394"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Botones -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Margin="0,6,0,20">
            <Button Classes="btn-volver" Content="&#x2190; Volver" Command="{Binding VolverAResultadosCommand}"/>
            <Button Classes="btn-continuar" Content="Continuar a Extras  &#x203A;" Command="{Binding IrAExtrasCommand}"/>
        </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Border>

</UserControl>
