<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Allva.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300"
             x:Class="Allva.Desktop.Views.PasswordAdminDialogView"
             x:DataType="vm:PasswordAdminDialogViewModel">

    <UserControl.Styles>
        <Style Selector="Button.btn-primary">
            <Setter Property="Background" Value="#0b5394"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.btn-primary:pointerover">
            <Setter Property="Background" Value="#084171"/>
        </Style>

        <Style Selector="Button.btn-secondary">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#cccccc"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.btn-secondary:pointerover">
            <Setter Property="Background" Value="#f5f5f5"/>
        </Style>

        <Style Selector="TextBox.password-input">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#0b5394"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="PasswordChar" Value="●"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <!-- Fondo semitransparente -->
        <Border Background="#80000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"/>

        <!-- Diálogo principal -->
        <Border Background="White"
                CornerRadius="16"
                Padding="0"
                MaxWidth="450"
                BoxShadow="0 12 40 0 #60000000"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Header -->
                <Border Grid.Row="0"
                        Background="#0b5394"
                        CornerRadius="16,16,0,0"
                        Padding="32,24">
                    <StackPanel Spacing="8">
                        <TextBlock Text="🔒 Acceso Restringido"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Ingrese la contraseña de administración"
                                   FontSize="14"
                                   Foreground="#E0E0E0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Content -->
                <StackPanel Grid.Row="1"
                            Spacing="24"
                            Margin="32,32">

                    <!-- Información -->
                    <Border Background="#F0F7FF"
                            CornerRadius="10"
                            Padding="16">
                        <TextBlock TextWrapping="Wrap"
                                   FontSize="13"
                                   Foreground="#0b5394"
                                   TextAlignment="Center">
                            <Run Text="Esta sección requiere autorización."/>
                            <LineBreak/>
                            <Run Text="Solo usuarios autorizados pueden acceder."/>
                        </TextBlock>
                    </Border>

                    <!-- Input de contraseña -->
                    <StackPanel Spacing="12">
                        <TextBlock Text="Contraseña de Administración"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#333333"/>
                        <TextBox Name="PasswordTextBox"
                                 Text="{Binding PasswordInput}"
                                 Classes="password-input"
                                 Watermark="Ingrese la contraseña..."
                                 PasswordChar="●"
                                 MaxLength="50"/>
                    </StackPanel>

                    <!-- Mensaje de error -->
                    <Border IsVisible="{Binding MostrarError}"
                            Background="#FFE6E6"
                            BorderBrush="#DC3545"
                            BorderThickness="2"
                            CornerRadius="8"
                            Padding="16,12">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="10">
                            <TextBlock Text="❌"
                                       FontSize="16"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding MensajeError}"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="#DC3545"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- Footer con botones -->
                <Border Grid.Row="2"
                        Background="#F8F9FA"
                        BorderThickness="0,1,0,0"
                        BorderBrush="#E8E8E8"
                        CornerRadius="0,0,16,16"
                        Padding="32,24">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <!-- Espacio vacío a la izquierda -->
                        <Border Grid.Column="0"/>

                        <!-- Botón Cancelar -->
                        <Button Grid.Column="1"
                                Classes="btn-secondary"
                                Content="Cancelar"
                                Click="OnCancelar"
                                Margin="0,0,12,0"
                                MinWidth="100"/>

                        <!-- Botón Verificar -->
                        <Button Grid.Column="2"
                                Classes="btn-primary"
                                Content="Verificar"
                                Click="OnVerificar"
                                IsEnabled="{Binding !ValidandoPassword}"
                                MinWidth="120"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- Indicador de carga superpuesto -->
        <Border IsVisible="{Binding ValidandoPassword}"
                Background="#D0FFFFFF"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border Background="White"
                    CornerRadius="12"
                    Padding="32,24"
                    BoxShadow="0 4 16 0 #40000000"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="16"
                            HorizontalAlignment="Center">
                    <TextBlock Text="Verificando..."
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#0b5394"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Por favor espere..."
                               FontSize="14"
                               Foreground="#666666"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
